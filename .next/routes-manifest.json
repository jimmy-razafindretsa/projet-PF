{
  "version": 3,
  "pages404": true,
  "caseSensitive": false,
  "basePath": "",
  "redirects": [
    {
      "source": "/:path+/",
      "destination": "/:path+",
      "internal": true,
      "statusCode": 308,
      "regex": "^(?:/((?:[^/]+?)(?:/(?:[^/]+?))*))/$"
    }
  ],
  "headers": [],
  "dynamicRoutes": [
    {
      "page": "/client_dashboard/order_detail/[id]",
      "regex": "^/client_dashboard/order_detail/([^/]+?)(?:/)?$",
      "routeKeys": {
        "nxtPid": "nxtPid"
      },
      "namedRegex": "^/client_dashboard/order_detail/(?<nxtPid>[^/]+?)(?:/)?$"
    },
    {
      "page": "/order_detail/[id]",
      "regex": "^/order_detail/([^/]+?)(?:/)?$",
      "routeKeys": {
        "nxtPid": "nxtPid"
      },
      "namedRegex": "^/order_detail/(?<nxtPid>[^/]+?)(?:/)?$"
    },
    {
      "page": "/supplier_dashboard/order_detail/[id]",
      "regex": "^/supplier_dashboard/order_detail/([^/]+?)(?:/)?$",
      "routeKeys": {
        "nxtPid": "nxtPid"
      },
      "namedRegex": "^/supplier_dashboard/order_detail/(?<nxtPid>[^/]+?)(?:/)?$"
    }
  ],
  "staticRoutes": [
    {
      "page": "/",
      "regex": "^/(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/(?:/)?$"
    },
    {
      "page": "/_not-found",
      "regex": "^/_not\\-found(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/_not\\-found(?:/)?$"
    },
    {
      "page": "/client_dashboard",
      "regex": "^/client_dashboard(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/client_dashboard(?:/)?$"
    },
    {
      "page": "/client_dashboard/completed",
      "regex": "^/client_dashboard/completed(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/client_dashboard/completed(?:/)?$"
    },
    {
      "page": "/client_dashboard/new-order",
      "regex": "^/client_dashboard/new\\-order(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/client_dashboard/new\\-order(?:/)?$"
    },
    {
      "page": "/client_dashboard/production",
      "regex": "^/client_dashboard/production(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/client_dashboard/production(?:/)?$"
    },
    {
      "page": "/favicon.ico",
      "regex": "^/favicon\\.ico(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/favicon\\.ico(?:/)?$"
    },
    {
      "page": "/supplier_dashboard",
      "regex": "^/supplier_dashboard(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/supplier_dashboard(?:/)?$"
    },
    {
      "page": "/supplier_dashboard/completed",
      "regex": "^/supplier_dashboard/completed(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/supplier_dashboard/completed(?:/)?$"
    },
    {
      "page": "/supplier_dashboard/production",
      "regex": "^/supplier_dashboard/production(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/supplier_dashboard/production(?:/)?$"
    }
  ],
  "dataRoutes": [],
  "rsc": {
    "header": "RSC",
    "varyHeader": "RSC, Next-Router-State-Tree, Next-Router-Prefetch, Next-Router-Segment-Prefetch",
    "prefetchHeader": "Next-Router-Prefetch",
    "didPostponeHeader": "x-nextjs-postponed",
    "contentTypeHeader": "text/x-component",
    "suffix": ".rsc",
    "prefetchSuffix": ".prefetch.rsc",
    "prefetchSegmentHeader": "Next-Router-Segment-Prefetch",
    "prefetchSegmentSuffix": ".segment.rsc",
    "prefetchSegmentDirSuffix": ".segments"
  },
  "rewriteHeaders": {
    "pathHeader": "x-nextjs-rewritten-path",
    "queryHeader": "x-nextjs-rewritten-query"
  },
  "rewrites": []
}